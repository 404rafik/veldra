# Veldra Cloud — Environment Configuration
# Copy this to .env and fill in values.

# Database
DATABASE_URL=postgres://user:password@localhost:5432/veldra

# JWT secret for authenticating WordPress sites (generate with: openssl rand -hex 64)
JWT_SECRET=change-me-to-a-random-secret

# Server
PORT=3000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info
