{
  "name": "devghtx/veldra",
  "description": "Privacy-first, cookie-free WordPress analytics plugin. GDPR-compliant, EU-hosted.",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.2",
    "composer/installers": "^2.2",
    "geoip2/geoip2": "^3.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "php-stubs/wordpress-stubs": "^6.4",
    "10up/wp_mock": "^1.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "Veldra\\": "src/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --level=8 src/",
    "lint": "phpcs --standard=PSR12 src/",
    "fix": "phpcbf --standard=PSR12 src/"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
